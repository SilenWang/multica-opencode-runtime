# for multica login
MULTICA_SERVER_URL=https://multica.ai
MULTICA_TOKEN=YOU_TOKEN

# runtime container name(for restart)
CONTAINER_NAME=YOU_CONTAINER_NAME_FOR_RUNTIME

# API tokens for opencode providers
DEEPSEEK_TOKEN=YOU_DEEPSEEK_TOKEN
OPENCODE_GO_TOKEN=YOU_OPENCODE_GO_TOKEN

# Claude Code provider selection (deepseek or opencode-go)
CLAUDE_PROVIDER=deepseek

# OpenCode Go base URL (Anthropic-compatible endpoint, only used when CLAUDE_PROVIDER=opencode-go)
OPENCODE_GO_BASE_URL=https://api.opencode-go.com

# Optional: Claude Code model overrides (defaults are for DeepSeek)
# CLAUDE_OPUS_MODEL=deepseek-v4-pro[1m]
# CLAUDE_SONNET_MODEL=deepseek-v4-pro[1m]
# CLAUDE_HAIKU_MODEL=deepseek-v4-flash
# CLAUDE_SUBAGENT_MODEL=deepseek-v4-flash